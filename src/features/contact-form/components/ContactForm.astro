---
import { actions, isInputError } from "astro:actions";
import { ClientRouter } from "astro:transitions";
import { CONTACT_FIELD_LIMITS } from "../config/contact-field-limits";
import { CONTACT_SERVICES } from "../config/contact-services";

const result = Astro.getActionResult(actions.contact);
const error = result?.error;

const fieldErrors = isInputError(error) ? error.fields : {};
---

<ClientRouter />

<form action={actions.contact} method="POST">
	<label for="name">Name</label>
	<input transition:persist id="name" type="text" name="name" autocomplete="name" />
	<p>{fieldErrors.name?.join(", ")}</p>

	<label for="email">Email</label>
	<input transition:persist id="email" type="email" name="email" autocomplete="email" />
	<p>{fieldErrors.email?.join(", ")}</p>

	<label for="phone">Phone</label>
	<input transition:persist id="phone" type="tel" name="phone" autocomplete="tel" />
	<p>{fieldErrors.phone?.join(", ")}</p>

	<label for="service">Service</label>
	<select transition:persist id="service" name="service">
		<option value="">Select a legal service</option>
		{CONTACT_SERVICES.map((area) => <option value={area}>{area}</option>)}
	</select>
	<p>{fieldErrors.service?.join(", ")}</p>

	<label for="message">Message</label>
	<span id="message-count">0 / {CONTACT_FIELD_LIMITS.message.max}</span>
	<textarea
		transition:persist
		id="message"
		name="message"
		rows="4"
		maxlength={CONTACT_FIELD_LIMITS.message.max}
		aria-describedby="message-count"></textarea>
	<p>{fieldErrors.message?.join(", ")}</p>

	<div aria-hidden="true">
		<label for="website">Website</label>
		<input
			transition:persist
			id="website"
			type="text"
			name="website"
			tabindex="-1"
			autocomplete="off"
		/>
		<p>{fieldErrors.website?.join(", ")}</p>
	</div>

	{
		result?.error && !isInputError(result.error) && (
			<p>Something went wrong. Please try again later.</p>
		)
	}

	<button type="submit">Send message</button>
</form>

<script>
	import "../scripts/messageCounter";
</script>
