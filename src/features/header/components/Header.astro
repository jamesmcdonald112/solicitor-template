---
import companyLogo from "../../assets/logo/companyLogo.svg?raw";
import hamburgerMenu from "../../assets/navbar/hambugerMenu.svg?raw";
import { firm } from "../../config/firm";
import { nav } from "../../config/nav";
import Brand from "./Brand.astro";
import MobileMenuButton from "./MobileMenuButton.astro";
import MobileMenuDialog from "./MobileMenuDialog.astro";

const { companyName, phone } = firm;
---

<!-- Header scaffold.
     Use `firm` for company and phone data.
     Use `nav` for primary navigation links.
     Keep the brand link, mobile menu trigger, and mobile menu dialog.
     Layout, ordering, and presentation can be rebuilt as needed. -->
<header data-header>
	<!-- Brand / home link goes here. -->
	<Brand companyLogo={companyLogo} companyName={companyName} />

	<!-- Primary navigation goes here.
	     Render links from `nav`. -->

	<!-- Phone or contact CTA can go here using:
	     - `phone.phoneHref`
	     - `phone.display` -->

	<!-- Mobile menu trigger goes here. -->
	<MobileMenuButton
		icon={hamburgerMenu}
		border={true}
		srLabel={"Open Mobile Menu"}
		action={"open"}
		class={""}
	/>

	<!-- Mobile menu dialog goes here.
	     It should expose brand context and render navigation / contact actions as needed. -->
	<MobileMenuDialog companyLogo={companyLogo} ariaLabel={companyName}>
		<!-- Mobile navigation and mobile contact actions go here.
		     Available data:
		     - `nav`
		     - `phone.phoneHref`
		     - `phone.display` -->
	</MobileMenuDialog>
</header>

<script>
	import "../scripts/header-menu.ts";
</script>
