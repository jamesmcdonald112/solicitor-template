---
interface MobileMenuButtonProps {
	icon: string;
	border?: boolean;
	srLabel: string;
	action: "open" | "close";
	controlsId?: string;
	class?: string;
}

const {
	icon,
	border = false,
	srLabel,
	action,
	controlsId = "mobile-menu",
	class: className = "",
} = Astro.props as MobileMenuButtonProps;
---

<!-- Mobile menu button scaffold.
     Keep:
     - accessible label via `srLabel`
     - `aria-controls`
     - `data-action` for open/close behavior
     - icon rendering from `icon`
     Layout and presentation can be rebuilt as needed.
     `border` remains available as an optional presentation hint if needed later. -->
<button
	type="button"
	class={className}
	aria-controls={controlsId}
	data-action={action}
>
	<span>{srLabel}</span>
	<span set:html={icon} />
</button>
