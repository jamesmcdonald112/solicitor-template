---
interface BrandProps {
	companyLogo: string;
	companyName?: string;
	href?: string;
	class?: string;
}

const {
	companyLogo,
	companyName,
	href = "/",
	class: className = "",
} = Astro.props as BrandProps;
---

<a
	href={href}
	aria-label={companyName ? `${companyName} home` : "Home"}
	class={className}
>
	<!-- Brand link scaffold.
	     Render the company logo from `companyLogo`.
	     Optionally render the company name from `companyName`.
	     Layout and presentation can be rebuilt as needed. -->

	<span set:html={companyLogo} />

	{companyName && <span>{companyName}</span>}
</a>
