---
import closeMenuIcon from "../../assets/navbar/closeMenuIcon.svg?raw";
import Brand from "./Brand.astro";
import MobileMenuButton from "./MobileMenuButton.astro";

interface MobileMenuDialogProps {
	companyLogo: string;
	ariaLabel: string;
}

const { companyLogo, ariaLabel } = Astro.props as MobileMenuDialogProps;
---

<dialog
	id="mobile-menu"
	data-mobile-menu
>
	<!-- Mobile menu dialog scaffold.
	     Keep:
	     - `id="mobile-menu"` for button/dialog connection
	     - `data-mobile-menu` for behavior hooks
	     - `data-overlay` for overlay handling if used by scripts
	     - brand context
	     - close button
	     - default slot for menu content
	     Layout and presentation can be rebuilt as needed. -->
	<div data-overlay tabindex="0">
		<!-- Brand / identity context goes here. -->
		<Brand companyLogo={companyLogo} companyName={ariaLabel} />

		<!-- Close button goes here. -->
		<MobileMenuButton
			icon={closeMenuIcon}
			border={false}
			srLabel={"Close Mobile Menu"}
			action={"close"}
			class={""}
		/>

		<!-- Mobile menu content goes here. -->
		<slot />
	</div>
</dialog>
