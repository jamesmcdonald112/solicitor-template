---
/*
  LAYOUT: BaseLayout
  PURPOSE: Root HTML shell for every page. Handles <head>, meta, OG, structured data.
  IMPORTS: global.css (which chains all other CSS), firm config for SEO defaults.
  FONTS: Font imports go here (e.g. @fontsource imports) — loaded once, globally.
  SLOTS: Default slot wraps in <main>. Navbar and Footer are rendered outside the slot.
  SEO: All meta/OG/Twitter/structured data is handled via typed props.
  DO NOT: Add page-specific styles here. Add layout-specific compositions in CUBE compositions file.
  CONNECTED TO: Every page file imports this layout.

  STAGE 3 REMINDER: Before building components, add font imports here:
    import "@fontsource/open-sans/400.css";
    import "@fontsource/open-sans/600.css";
    import "@fontsource/merriweather/400.css";
    import "@fontsource/merriweather/700.css";
  Then define --font-sans and --font-serif in tokens.css.
*/
import "../styles/global.css";
import { firm } from "../config/firm";

interface BaseLayoutProps {
	title?: string;
	description?: string;
	noIndex?: boolean;
	canonicalPath?: string;
	ogImage?: string;
	ogImageAlt?: string;
	ogType?: "website" | "article";
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
	publishedTime?: string;
	modifiedTime?: string;
	author?: string;
	section?: string;
	tags?: string[];
}

const {
	title = firm.seo.defaultTitle,
	description = firm.seo.defaultDescription,
	noIndex = false,
	canonicalPath,
	ogImage = firm.seo.defaultOgImage,
	ogImageAlt = firm.seo.defaultOgImageAlt,
	ogType = "website",
	structuredData,
	publishedTime,
	modifiedTime,
	author,
	section,
	tags = [],
} = Astro.props as BaseLayoutProps;

const canonical = firm.siteUrl
	? new URL(canonicalPath ?? Astro.url.pathname, firm.siteUrl).toString()
	: undefined;

const ogImageUrl = firm.siteUrl && ogImage ? new URL(ogImage, firm.siteUrl).toString() : undefined;

const isArticle = ogType === "article";
---

<!doctype html>
<html lang="en-IE">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="format-detection" content="telephone=no, address=no, email=no" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" href="/images/favicon/favicon.svg" type="image/svg+xml" />
		{canonical && <link rel="canonical" href={canonical} />}
		{noIndex && <meta name="robots" content="noindex, nofollow" />}
		<meta property="og:site_name" content={firm.companyName} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonical && <meta property="og:url" content={canonical} />}
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content="en_IE" />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{ogImageUrl && <meta property="og:image:secure_url" content={ogImageUrl} />}
		{ogImageUrl && <meta property="og:image:type" content="image/webp" />}
		{ogImageUrl && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
		{ogImageUrl && <meta property="og:image:width" content="1200" />}
		{ogImageUrl && <meta property="og:image:height" content="630" />}
		{
			isArticle && publishedTime && (
				<meta property="article:published_time" content={publishedTime} />
			)
		}
		{isArticle && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		{isArticle && author && <meta property="article:author" content={author} />}
		{isArticle && section && <meta property="article:section" content={section} />}
		{isArticle && tags.length > 0 && tags.map((t) => <meta property="article:tag" content={t} />)}
		<meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
		{ogImageUrl && ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

		{canonical && <meta name="twitter:url" content={canonical} />}
		{
			structuredData && (
				<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
			)
		}
	</head>
	<body>
		<main><slot /></main>
	</body>
</html>
